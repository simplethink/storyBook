<view class="record-container">
  <!-- 日期标题 -->
  <view class="date-header">
    <text class="date-text">{{formatDate(selectedDate)}}</text>
  </view>

  <!-- 阅读记录列表 -->
  <view class="records-section">
    <view class="section-title">
      <text>阅读记录</text>
      <button class="add-btn" size="mini" bindtap="addReadingRecord">+ 添加</button>
    </view>
    
    <view class="record-list" wx:if="{{readingRecords.length > 0}}">
      <view 
        class="record-card"
        wx:for="{{readingRecords}}"
        wx:key="id"
        bindtap="viewRecordDetail"
        data-record="{{item}}"
      >
        <image class="book-cover" src="{{item.coverUrl}}" mode="aspectFill" wx:if="{{item.coverUrl}}"></image>
        <view class="record-info" wx:if="{{!item.coverUrl}}">
          <text class="book-title">{{item.bookName || '未命名图书'}}</text>
          <text class="book-author">{{item.author || ''}}</text>
        </view>
        <view class="record-meta">
          <text class="pages">P{{item.startPage}}-{{item.endPage}}</text>
          <text class="duration">{{item.duration}}分钟</text>
          <text class="time" wx:if="{{item.readingTime}}">🕐 {{item.readingTime}}</text>
        </view>
        <view class="note" wx:if="{{item.note}}">
          <text>{{item.note}}</text>
        </view>
      </view>
    </view>
    
    <view class="empty-state" wx:else>
      <text class="empty-icon">📚</text>
      <text class="empty-text">暂无阅读记录</text>
    </view>
  </view>

  <!-- 复习任务列表 -->
  <view class="review-section">
    <view class="section-title">
      <text>复习提醒</text>
      <button class="add-btn" size="mini" bindtap="addReviewTask">+ 添加</button>
    </view>
    
    <view class="review-list" wx:if="{{reviewTasks.length > 0}}">
      <view 
        class="review-card {{item.completed ? 'completed' : ''}}"
        wx:for="{{reviewTasks}}"
        wx:key="id"
      >
        <checkbox 
          checked="{{item.completed}}" 
          bindchange="toggleReviewTask"
          data-id="{{item.id}}"
          class="review-checkbox"
        />
        <view class="review-content">
          <text class="review-book">{{item.bookName}}</text>
          <text class="review-stage">第{{item.stage}}次复习 - {{getReviewStageName(item.stage)}}</text>
        </view>
        <view class="review-actions">
          <button class="action-icon" bindtap="completeReview" data-id="{{item.id}}">✓</button>
        </view>
      </view>
    </view>
    
    <view class="empty-state" wx:else>
      <text class="empty-icon">⏰</text>
      <text class="empty-text">暂无复习任务</text>
    </view>
  </view>

  <!-- 底部浮动按钮 -->
  <view class="fab-container">
    <view class="fab-btn" bindtap="showAddMenu">
      <text class="fab-icon">+</text>
    </view>
  </view>
</view>

<!-- 添加菜单弹窗 -->
<view class="modal-mask" wx:if="{{showAddMenu}}" bindtap="hideAddMenu">
  <view class="add-menu" catchtap="stopPropagation">
    <view class="menu-item" bindtap="scanBarcode">
      <text class="menu-icon">📷</text>
      <text class="menu-text">扫码条形码</text>
    </view>
    <view class="menu-item" bindtap="takePhoto">
      <text class="menu-icon">📸</text>
      <text class="menu-text">拍封面添加</text>
    </view>
    <view class="menu-item" bindtap="manualAdd">
      <text class="menu-icon">✏️</text>
      <text class="menu-text">手动输入</text>
    </view>
  </view>
</view>
