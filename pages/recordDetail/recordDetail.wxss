/* 读书记录页面样式 */
.record-container {
  padding: 20rpx;
  padding-bottom: 140rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 日期标题 */
.date-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.date-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

/* 区块标题 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
}

.section-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background-color: #2196f3;
  color: #fff;
  border: none;
  border-radius: 32rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
}

/* 记录卡片 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.book-cover {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  background-color: #f5f5f5;
}

.record-info {
  margin-bottom: 20rpx;
}

.book-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.book-author {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.record-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.pages, .duration {
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.note {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding: 15rpx;
  background-color: #fff9e6;
  border-left: 4rpx solid #ff9800;
  border-radius: 8rpx;
}

/* 复习卡片 */
.review-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.review-card.completed {
  opacity: 0.6;
}

.review-checkbox {
  transform: scale(1.2);
}

.review-content {
  flex: 1;
}

.review-book {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.review-stage {
  display: block;
  font-size: 24rpx;
  color: #ff9800;
}

.review-actions {
  display: flex;
  gap: 10rpx;
}

.action-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #4caf50;
  color: #fff;
  font-size: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  padding: 0;
  line-height: 60rpx;
}

/* 空状态 */
.empty-state {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 浮动按钮 */
.fab-container {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  z-index: 100;
}

.fab-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
}

.fab-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.add-menu {
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  width: 100%;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 48rpx;
}

.menu-text {
  font-size: 32rpx;
  color: #333;
}

/* 区块 */
.records-section, .review-section {
  background-color: transparent;
  margin-bottom: 40rpx;
}
