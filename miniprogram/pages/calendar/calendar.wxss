/* 日历页面样式 */
.calendar-container {
  padding: 20rpx;
  background-color: #fff;
  min-height: 100vh;
}

/* 月份选择器 */
.month-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.arrow-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 50%;
}

.arrow {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
}

.month-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 星期标题 */
.weekdays {
  display: flex;
  border-bottom: 2rpx solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 10rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

/* 日期网格 */
.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.day-item {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  border-radius: 16rpx;
  background-color: #f9f9f9;
}

.day-item.other-month {
  opacity: 0.3;
}

.day-item.today {
  background-color: #e3f2fd;
}

.day-item.selected {
  background-color: #2196f3;
}

.day-item.selected .day-number {
  color: #fff;
}

.day-item.has-record {
  background-color: #e8f5e9;
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.record-indicator {
  width: 12rpx;
  height: 12rpx;
  background-color: #4caf50;
  border-radius: 50%;
  margin-top: 8rpx;
}

.review-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff9800;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

/* 图例说明 */
.legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 40rpx;
  padding: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.legend-dot.has-record {
  background-color: #4caf50;
}

.legend-dot.review-dot {
  background-color: #ff9800;
}

.legend-item text {
  font-size: 24rpx;
  color: #666;
}

/* 底部操作按钮 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: 2rpx solid #ddd;
  background-color: #fff;
}

.action-btn.primary {
  background-color: #2196f3;
  color: #fff;
  border-color: #2196f3;
}
