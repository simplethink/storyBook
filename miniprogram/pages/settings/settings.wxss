/* 设置页面样式 */
.settings-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.setting-card {
  background-color: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.card-header {
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.setting-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.setting-info {
  flex: 1;
  margin-right: 20rpx;
}

.setting-label {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.setting-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.info-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}

.info-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}

.highlight {
  display: block;
  margin-top: 10rpx;
  font-weight: bold;
  color: #fff;
}

.tip {
  display: block;
  margin-top: 15rpx;
  font-style: italic;
  color: rgba(255, 255, 255, 0.8);
}
