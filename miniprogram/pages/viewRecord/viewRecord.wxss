/* 记录详情页面样式 */
.detail-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 封面区域 */
.cover-section {
  margin-bottom: 30rpx;
  text-align: center;
}

.book-cover {
  width: 300rpx;
  height: 420rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.no-cover {
  width: 300rpx;
  height: 420rpx;
  border-radius: 16rpx;
  background-color: #f0f0f0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
}

.no-cover-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.no-cover-text {
  font-size: 28rpx;
  color: #999;
}

/* 信息区域 */
.info-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.book-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.book-author {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.meta-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.meta-item {
  flex: 1;
  min-width: 200rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.meta-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 笔记区域 */
.note-section {
  background-color: #fff9e6;
  border-left: 6rpx solid #ff9800;
  border-radius: 12rpx;
  padding: 30rpx;
}

.note-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.note-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.edit-btn {
  background-color: #2196f3;
  color: #fff;
}

.delete-btn {
  background-color: #f44336;
  color: #fff;
}
